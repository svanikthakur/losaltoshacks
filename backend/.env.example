# ─── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace-me-with-a-long-random-string

# ─── OpenAI (powers all 5 agents) ────────────────────────
OPENAI_API_KEY=

# ─── Supabase (optional — falls back to in-memory) ───────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ─── Redis / BullMQ (optional — falls back to in-process) ─
REDIS_URL=

# ─── Serper (Google Search — free 2500/mo) ───────────────
SERPER_API_KEY=

# ─── Pexels (free images for pitch deck — 200 req/hour) ──
PEXELS_API_KEY=

# ─── SendGrid (free 100/day) ─────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ─── GitHub (scaffold repos) ─────────────────────────────
GITHUB_TOKEN=
GITHUB_USERNAME=

# ─── Google OAuth (Slides / Calendar) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── Hunter.io (VC email lookup, 25/mo) ──────────────────
HUNTER_API_KEY=

# ─── Notion ──────────────────────────────────────────────
NOTION_API_KEY=
NOTION_TEMPLATE_PAGE_ID=

# ─── Vercel deploy ───────────────────────────────────────
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ─── Product Hunt (Collision Score — free, Developer Token) ──
PRODUCT_HUNT_DEV_TOKEN=
# Fallback if you used OAuth client-credentials instead:
PRODUCT_HUNT_CLIENT_ID=
PRODUCT_HUNT_CLIENT_SECRET=
